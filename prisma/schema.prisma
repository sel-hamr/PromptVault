generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum ModelTarget {
  CHATGPT
  CLAUDE
  MIDJOURNEY
  GEMINI
  DALLE
  STABLE_DIFFUSION
  UNIVERSAL
}

enum Visibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum PieceType {
  PERSONA
  FORMAT
  CONSTRAINT
  CONTEXT
  TONE
  CUSTOM
}

model User {
  id            String   @id @default(cuid())
  username      String   @unique
  email         String   @unique
  password_hash String
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  prompts       Prompt[]
  prompt_pieces PromptPiece[]
}

model Prompt {
  id             String      @id @default(cuid())
  user_id        String
  title          String
  description    String?
  content        String
  model_target   ModelTarget
  visibility     Visibility  @default(PRIVATE)
  category_id    String?
  forked_from_id String?
  variables      Json        @default("[]")
  avg_rating     Float       @default(0)
  rating_count   Int         @default(0)
  fork_count     Int         @default(0)
  use_count      Int         @default(0)
  version_count  Int         @default(1)
  created_at     DateTime    @default(now())
  updated_at     DateTime    @updatedAt

  user        User      @relation(fields: [user_id], references: [id])
  category    Category? @relation(fields: [category_id], references: [id])
  forked_from Prompt?   @relation("PromptForks", fields: [forked_from_id], references: [id])
  forks       Prompt[]  @relation("PromptForks")
  tags        PromptTag[]

  @@index([user_id])
  @@index([visibility])
  @@index([category_id])
  @@index([model_target])
  @@index([avg_rating(sort: Desc)])
  @@index([created_at(sort: Desc)])
}

model PromptPiece {
  id         String     @id @default(cuid())
  user_id    String
  title      String
  content    String
  piece_type PieceType
  variables  Json       @default("[]")
  visibility Visibility @default(PRIVATE)
  use_count  Int        @default(0)
  created_at DateTime   @default(now())
  updated_at DateTime   @updatedAt

  user User @relation(fields: [user_id], references: [id])
}

model Category {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  parent_id    String?
  depth        Int      @default(0)
  prompt_count Int      @default(0)
  created_at   DateTime @default(now())

  parent   Category?  @relation("CategoryTree", fields: [parent_id], references: [id])
  children Category[] @relation("CategoryTree")
  prompts  Prompt[]
}

model Tag {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  usage_count Int       @default(0)
  prompts     PromptTag[]

  @@index([slug])
}

model PromptTag {
  prompt_id String
  tag_id    String

  prompt Prompt @relation(fields: [prompt_id], references: [id])
  tag    Tag    @relation(fields: [tag_id], references: [id])

  @@id([prompt_id, tag_id])
}
